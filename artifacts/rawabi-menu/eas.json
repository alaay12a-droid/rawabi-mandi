{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "image": "latest"
      },
      "node": "22.15.0",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://mandi-menu-1.replit.app"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "image": "latest"
      },
      "node": "22.15.0",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://mandi-menu-1.replit.app"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal",
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "applicationId": "com.rwabi.almndi"
      }
    }
  }
}
