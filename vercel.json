{
  "version": 2,
  "buildCommand": "npm install -g pnpm@9 && pnpm install --frozen-lockfile && pnpm --filter @workspace/api-server run build",
  "installCommand": "npm install -g pnpm@9 && pnpm install --frozen-lockfile",
  "outputDirectory": "artifacts/api-server/dist",
  "functions": {
    "artifacts/api-server/src/index.ts": {
      "runtime": "nodejs22.x",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/src/index.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
